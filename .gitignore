# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually fine to prevent conflicts.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you want to keep lock files out of git, you can uncomment the following line.
#Lockfile-untracked

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be committed.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be committed.
#   pdm.lock
.pdm-plugins/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

