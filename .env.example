# --- Primary LLM Provider (OpenAI Compatible) ---
# API key của nhà cung cấp LLM chính (ví dụ: OpenAI, vLLM, LMStudio, Ollama)
PRIMARY_LLM_API_KEY=sk-692d436dc1b857e4-9bvu9t-e40d5562
PRIMARY_LLM_BASE_URL=http://localhost:20128/v1
DEFAULT_MODEL=gh/gpt-4

# --- Fallback LLM Provider (OpenAI Compatible) ---
# Dùng để dự phòng khi nhà cung cấp chính gặp lỗi (ví dụ: Groq, DeepSeek)
FALLBACK_LLM_API_KEY=gsk_your-fallback-api-key-here
FALLBACK_LLM_BASE_URL=https://api.groq.com/openai/v1
FALLBACK_MODEL=llama3-8b-8192

# --- Cấu hình Frontend ---
# Dành cho Streamlit Admin Dashboard (Mặc định khi chạy local là http://localhost:8000/api)
# Khi deploy bằng Docker hoặc trên Cloud, hãy đổi sang IP/Domain thật.
API_BASE_URL=http://localhost:8000/api

# --- Cấu hình Khác ---
# Tắt Telemetry thu thập dữ liệu ẩn danh của ChromaDB để bảo mật thông tin nội bộ
ANONYMIZED_TELEMETRY=False
